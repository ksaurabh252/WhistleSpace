# .gitignore for WhistleSpace (Backend)

# Environment variables
.env
.env.local
.env.development
.env.production
feedback.routes_.js
test.routes.js

# Dependency directories
node_modules/
dist/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
*.pid
*.seed
*.pid.lock

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace

# Build files
build/
coverage/

# Database
*.db
*.sqlite
mongodata/

# macOS
.DS_Store

# Testing
/test/
/coverage/

# Misc
*.bak
*.tmp
*.patch
.cache/
.temp/
# Specific environment files
client/.env
server/.env
